---
import Base from '../../layouts/Base.astro';
---

<Base
  title="Get Involved"
  description="Get involved with Friends of Gledhow Valley Woods — volunteer at action mornings, become a member, or donate to support our conservation work."
  section="get-involved"
>
  <section class="bg-bluebell-800 text-white py-16 md:py-24 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-bluebell-900 to-bluebell-700 opacity-90"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="font-heading font-bold text-5xl md:text-7xl text-white mb-5">Get Involved</h1>
      <p class="font-body text-bluebell-100 text-xl max-w-2xl leading-relaxed">
        Gledhow Valley Woods is protected and improved entirely thanks to volunteers, members, and supporters. There are three ways you can help.
      </p>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14 md:py-20">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <a href="/get-involved/volunteering" class="group block bg-white rounded-lg p-6 border border-bluebell-200 shadow-sm hover:shadow-md transition-shadow">
        <div class="text-4xl mb-3">🙌</div>
        <h2 class="font-heading font-bold text-bluebell-800 text-2xl mb-2 group-hover:text-bluebell-600 transition-colors">Volunteering</h2>
        <p class="text-earth-700 text-sm font-body leading-relaxed">
          Join an action morning, help at events, or get involved with our water testing and conservation work.
        </p>
        <span class="mt-3 inline-block text-sm font-sans font-semibold text-bluebell-700 group-hover:underline">Find out more →</span>
      </a>

      <a href="/get-involved/membership" class="group block bg-white rounded-lg p-6 border border-bluebell-200 shadow-sm hover:shadow-md transition-shadow">
        <div class="text-4xl mb-3">🌳</div>
        <h2 class="font-heading font-bold text-bluebell-800 text-2xl mb-2 group-hover:text-bluebell-600 transition-colors">Becoming a Member</h2>
        <p class="text-earth-700 text-sm font-body leading-relaxed">
          Membership costs just £5 per year or £50 for life, and gives you a vote at our AGM.
        </p>
        <span class="mt-3 inline-block text-sm font-sans font-semibold text-bluebell-700 group-hover:underline">Join FGVW →</span>
      </a>

      <a href="/get-involved/donating" class="group block bg-white rounded-lg p-6 border border-bluebell-200 shadow-sm hover:shadow-md transition-shadow">
        <div class="text-4xl mb-3">💛</div>
        <h2 class="font-heading font-bold text-bluebell-800 text-2xl mb-2 group-hover:text-bluebell-600 transition-colors">Donating</h2>
        <p class="text-earth-700 text-sm font-body leading-relaxed">
          Every donation helps fund conservation work, citizen science, and community events in the valley.
        </p>
        <span class="mt-3 inline-block text-sm font-sans font-semibold text-bluebell-700 group-hover:underline">Make a donation →</span>
      </a>
    </div>
  </section>
</Base>
