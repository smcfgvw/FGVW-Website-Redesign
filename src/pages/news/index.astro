---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allNews = await getCollection('news');
const sortedNews = allNews.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const categoryLabels: Record<string, string> = {
  'projects':      'Projects',
  'water-testing': 'Water Testing',
  'green-fair':    'Green Fair',
  'general':       'General',
};

const categoryColours: Record<string, string> = {
  'projects':      'bg-forest-100 text-forest-700',
  'water-testing': 'bg-blue-100 text-blue-700',
  'green-fair':    'bg-fair-100 text-fair-700',
  'general':       'bg-cream-200 text-earth-600',
};

function formatDate(d: Date) {
  return d.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<Base
  title="News"
  description="News from Friends of Gledhow Valley Woods — conservation projects, water testing updates, Green Fair news, and more."
  section="news"
>
  <section class="bg-forest-800 text-white py-12 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-forest-900 to-forest-700 opacity-90"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="font-heading font-bold text-5xl md:text-6xl text-white">News</h1>
      <p class="font-body text-cream-200 text-xl mt-4 max-w-2xl">
        Updates from FGVW — conservation work, water monitoring, community events, and more.
      </p>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
    {sortedNews.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {sortedNews.map(post => (
          <article class="bg-white rounded-lg border border-cream-400 shadow-sm overflow-hidden hover:shadow-md transition-shadow">
            <!-- Image placeholder -->
            <div class="bg-forest-100 h-40 flex items-center justify-center border-b border-cream-300">
              <span class="text-forest-400 font-sans text-xs text-center px-3">Image placeholder</span>
            </div>
            <div class="p-5">
              <div class="flex items-center gap-2 mb-3">
                <span class={`text-xs font-sans font-semibold px-2 py-0.5 rounded-full ${categoryColours[post.data.category]}`}>
                  {categoryLabels[post.data.category]}
                </span>
                <time class="text-xs font-sans text-earth-500" datetime={post.data.date.toISOString()}>
                  {formatDate(post.data.date)}
                </time>
              </div>
              <h2 class="font-heading font-semibold text-forest-800 text-xl leading-snug mb-2">
                <a href={`/news/${post.slug}`} class="hover:text-forest-600 transition-colors">
                  {post.data.title}
                </a>
              </h2>
              {post.data.excerpt && (
                <p class="text-earth-700 font-body text-sm leading-relaxed">{post.data.excerpt}</p>
              )}
              <a href={`/news/${post.slug}`} class="mt-3 inline-block text-sm font-sans font-semibold text-forest-700 hover:underline">
                Read more →
              </a>
            </div>
          </article>
        ))}
      </div>
    ) : (
      <p class="text-earth-600 font-body text-lg">No news posts yet — check back soon.</p>
    )}
  </section>
</Base>
