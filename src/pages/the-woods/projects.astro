---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
const active    = projects.filter(p => p.data.status === 'active');
const completed = projects.filter(p => p.data.status === 'completed');
---

<Base
  title="Projects & Improvements — The Woods"
  description="Conservation and improvement projects carried out by Friends of Gledhow Valley Woods."
  section="the-woods"
>
  <section class="bg-forest-800 text-white py-12 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-forest-900 to-forest-700 opacity-90"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-forest-200 font-sans text-sm mb-4" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white">Home</a> / <a href="/the-woods" class="hover:text-white">The Woods</a> / <span>Projects</span>
      </nav>
      <h1 class="font-heading font-bold text-4xl md:text-5xl text-white">Projects &amp; Improvements</h1>
      <p class="text-cream-200 font-body text-xl mt-4 max-w-2xl">
        Conservation, restoration, and improvement work carried out by FGVW volunteers and funded by grants and membership fees.
      </p>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">

    <h2 class="font-heading font-bold text-forest-900 text-3xl mb-6">Active Projects</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
      {active.map(p => (
        <article class="bg-white rounded-lg p-6 border border-cream-400 shadow-sm border-l-4 border-l-forest-600">
          <div class="flex items-start justify-between gap-2 mb-3">
            <h3 class="font-heading font-semibold text-forest-800 text-xl leading-snug">{p.data.title}</h3>
            <span class="shrink-0 bg-forest-100 text-forest-700 text-xs font-sans font-semibold px-2 py-1 rounded-full">Active</span>
          </div>
          <p class="text-earth-700 font-body text-sm leading-relaxed">{p.data.description}</p>
        </article>
      ))}
    </div>

    <h2 class="font-heading font-bold text-forest-900 text-3xl mb-6">Completed Projects</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {completed.map(p => (
        <article class="bg-white rounded-lg p-6 border border-cream-400 shadow-sm">
          <div class="flex items-start justify-between gap-2 mb-3">
            <h3 class="font-heading font-semibold text-forest-800 text-xl leading-snug">{p.data.title}</h3>
            <span class="shrink-0 bg-cream-200 text-earth-600 text-xs font-sans font-semibold px-2 py-1 rounded-full">Completed</span>
          </div>
          <p class="text-earth-700 font-body text-sm leading-relaxed">{p.data.description}</p>
        </article>
      ))}
    </div>

    <div class="mt-12 bg-cream-200 rounded-lg p-6 border border-cream-400">
      <h3 class="font-heading font-semibold text-forest-800 text-xl mb-2">Get involved</h3>
      <p class="text-earth-700 font-body text-sm leading-relaxed mb-4">
        Our practical conservation work is carried out by volunteers at regular work parties. No experience needed — all tools and guidance provided. Join us to help maintain and improve the woods for everyone.
      </p>
      <a href="/events" class="inline-block bg-forest-700 hover:bg-forest-800 text-white font-sans font-semibold text-sm px-5 py-2 rounded transition-colors">
        See upcoming events
      </a>
    </div>

    <div class="mt-8 pt-6 border-t border-cream-400">
      <a href="/the-woods" class="font-sans text-sm font-semibold text-forest-700 hover:underline">← Back to The Woods</a>
    </div>
  </section>
</Base>
