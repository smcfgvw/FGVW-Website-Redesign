---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const events = await getCollection('events');
  return events.map(event => ({ params: { slug: event.slug }, props: { event } }));
}

const { event } = Astro.props;
const { Content } = await event.render();

function formatDate(d: Date) {
  return d.toLocaleDateString('en-GB', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });
}
---

<Base
  title={event.data.title}
  description={event.data.description}
  section="events"
>
  <section class="bg-forest-800 text-white py-12 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-forest-900 to-forest-700 opacity-90"></div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-forest-200 font-sans text-sm mb-4" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white">Home</a> / <a href="/events" class="hover:text-white">Events</a> / <span>{event.data.title}</span>
      </nav>
      <h1 class="font-heading font-bold text-4xl md:text-5xl text-white leading-tight mb-4">{event.data.title}</h1>
      <div class="flex flex-wrap gap-4 text-forest-200 font-sans text-sm">
        <span>📅 {formatDate(event.data.date)}</span>
        {event.data.time && <span>🕐 {event.data.time}</span>}
        <span>📍 {event.data.location}</span>
      </div>
    </div>
  </section>

  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
    <div class="prose prose-lg font-body text-earth-800 max-w-none">
      <Content />
    </div>
    {event.data.bookingLink && (
      <div class="mt-8 p-5 bg-forest-50 border border-forest-200 rounded-lg">
        <a
          href={event.data.bookingLink}
          target="_blank" rel="noopener noreferrer"
          class="inline-block bg-forest-700 hover:bg-forest-800 text-white font-sans font-bold px-6 py-3 rounded transition-colors"
        >
          Book / find out more →
        </a>
      </div>
    )}
    <div class="mt-10 pt-8 border-t border-cream-400">
      <a href="/events" class="font-sans text-sm font-semibold text-forest-700 hover:underline">← All events</a>
    </div>
  </article>
</Base>
