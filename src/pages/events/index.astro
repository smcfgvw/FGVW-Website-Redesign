---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allEvents = await getCollection('events');
const now = new Date();
const upcoming = allEvents
  .filter(e => e.data.date >= now)
  .sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());
const past = allEvents
  .filter(e => e.data.date < now)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function formatDate(d: Date) {
  return d.toLocaleDateString('en-GB', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });
}
---

<Base
  title="Events"
  description="Upcoming events from Friends of Gledhow Valley Woods — work parties, walks, talks, and the annual Green Fair."
  section="events"
>
  <section class="bg-forest-800 text-white py-12 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-forest-900 to-forest-700 opacity-90"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="font-heading font-bold text-5xl md:text-6xl text-white">Events</h1>
      <p class="font-body text-cream-200 text-xl mt-4 max-w-2xl">
        Join us for work parties, guided walks, and our annual Green Fair.
      </p>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
    <h2 class="font-heading font-bold text-forest-900 text-3xl md:text-4xl mb-8">Upcoming events</h2>
    {upcoming.length > 0 ? (
      <div class="space-y-4 mb-16">
        {upcoming.map(event => (
          <article class="bg-white rounded-lg border border-cream-400 shadow-sm p-6 flex flex-col sm:flex-row gap-5">
            <!-- Date block -->
            <div class="shrink-0 bg-forest-700 text-white rounded-lg text-center w-20 py-3">
              <div class="text-xs font-sans font-medium uppercase text-forest-200">
                {event.data.date.toLocaleDateString('en-GB', { month: 'short' })}
              </div>
              <div class="text-3xl font-heading font-bold leading-none text-white">
                {event.data.date.getDate()}
              </div>
              <div class="text-xs font-sans text-forest-200">
                {event.data.date.getFullYear()}
              </div>
            </div>
            <!-- Details -->
            <div class="flex-1">
              <h3 class="font-heading font-semibold text-forest-800 text-2xl mb-1 leading-snug">
                <a href={`/events/${event.slug}`} class="hover:text-forest-600 transition-colors">
                  {event.data.title}
                </a>
              </h3>
              <div class="flex flex-wrap gap-3 text-sm font-sans text-earth-600 mb-3">
                {event.data.time && <span>🕐 {event.data.time}</span>}
                <span>📍 {event.data.location}</span>
                <span>📅 {formatDate(event.data.date)}</span>
              </div>
              <p class="text-earth-700 font-body text-sm leading-relaxed">{event.data.description}</p>
              {event.data.bookingLink && (
                <a
                  href={event.data.bookingLink}
                  target="_blank" rel="noopener noreferrer"
                  class="mt-3 inline-block bg-forest-700 hover:bg-forest-800 text-white font-sans font-semibold text-sm px-4 py-2 rounded transition-colors"
                >
                  Book / find out more →
                </a>
              )}
            </div>
          </article>
        ))}
      </div>
    ) : (
      <div class="bg-white rounded-lg border border-cream-400 p-8 text-center mb-16">
        <p class="text-earth-600 font-body text-lg">No upcoming events at the moment — check back soon.</p>
      </div>
    )}

    {past.length > 0 && (
      <>
        <h2 class="font-heading font-bold text-forest-900 text-3xl mb-6 text-earth-600">Past events</h2>
        <div class="space-y-3">
          {past.map(event => (
            <article class="bg-cream-100 rounded-lg border border-cream-400 p-4 flex items-center gap-4 opacity-70">
              <div class="shrink-0 text-earth-500 font-sans text-sm">
                {formatDate(event.data.date)}
              </div>
              <h3 class="font-heading font-semibold text-earth-700 text-lg">
                {event.data.title}
              </h3>
            </article>
          ))}
        </div>
      </>
    )}
  </section>
</Base>
