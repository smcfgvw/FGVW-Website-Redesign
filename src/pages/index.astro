---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allNews = await getCollection('news');
const latestNews = allNews
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const allEvents = await getCollection('events');
const now = new Date();
const upcomingEvents = allEvents
  .filter(e => e.data.date >= now)
  .sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf())
  .slice(0, 3);

function formatDate(d: Date) {
  return d.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<Base
  title="Friends of Gledhow Valley Woods"
  description="Friends of Gledhow Valley Woods — protecting and enhancing Gledhow Valley Woods in north Leeds since 1996. Join us, visit the woods, and learn about our water monitoring and annual Green Fair."
>
  <!-- HERO -->
  <section class="relative bg-forest-800 text-white overflow-hidden min-h-[480px] flex items-center">
    <div class="absolute inset-0">
      <img src="/images/PXL_20240430_172229616.jpg" alt="Woodland path through the canopy at Gledhow Valley Woods" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-forest-900/72"></div>
      <span class="absolute bottom-2 right-3 text-[10px] text-white/70 font-sans z-10">© Simon Conyers</span>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
      <p class="font-sans text-forest-200 text-sm font-medium tracking-widest uppercase mb-4">
        Registered Charity No. 1169599
      </p>
      <h1 class="font-heading font-bold text-4xl md:text-6xl lg:text-7xl text-white leading-tight mb-6 max-w-3xl">
        Protecting and enhancing Gledhow Valley Woods
      </h1>
      <p class="text-cream-200 text-lg md:text-xl max-w-2xl leading-relaxed mb-8 font-body">
        Gledhow Valley Woods is a ribbon of woodland and grassland running about 1.5 km through a suburban area of north Leeds.
        The Friends of Gledhow Valley Woods was set up in March 1996 to protect and enhance the natural beauty of the woods,
        increase public awareness, support other local groups, and liaise with all appropriate organisations to achieve our objectives.
      </p>
      <div class="flex flex-wrap gap-3">
        <a href="/get-involved/membership" class="bg-earth-500 hover:bg-earth-600 text-white font-sans font-semibold px-6 py-3 rounded transition-colors">
          Become a member
        </a>
        <a href="/the-woods" class="bg-white/10 hover:bg-white/20 border border-white/30 text-white font-sans font-semibold px-6 py-3 rounded transition-colors">
          Explore the woods
        </a>
      </div>
    </div>
  </section>

  <!-- PETITION BANNER -->
  <div class="bg-blue-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex flex-col sm:flex-row items-center justify-center gap-3 text-center">
      <p class="font-sans font-semibold text-blue-100 text-base md:text-lg">
        📢 Help us stop water pollution from misconnections in Gledhow Valley —
      </p>
      <a
        href="https://www.change.org/p/stop-water-pollution-from-misconnections-in-the-gledhow-valley?recruiter=642749081&recruited_by_id=0c466b30-b425-11e6-bdec-9b64f9cca636&redirect_reason=deprecated-url"
        target="_blank" rel="noopener noreferrer"
        class="inline-block bg-white text-blue-900 hover:bg-blue-100 font-sans font-bold text-sm px-5 py-2 rounded-full transition-colors whitespace-nowrap"
      >
        Sign the petition →
      </a>
    </div>
  </div>

  <!-- THREE FEATURED PANELS -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14 md:py-20">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

      <!-- The Woods -->
      <a href="/the-woods" class="group block bg-white rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow border border-gray-100">
        <div class="h-48 overflow-hidden relative">
          <img src="/images/PXL_20240430_170743255.jpg" alt="The pond at Gledhow Valley Woods in spring" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
          <span class="absolute bottom-1 right-2 text-[10px] text-white/70 font-sans">© Simon Conyers</span>
        </div>
        <div class="p-5">
          <h2 class="font-heading font-bold text-forest-800 text-2xl mb-2 group-hover:text-forest-600 transition-colors">The Woods</h2>
          <p class="text-earth-700 text-sm font-body leading-relaxed">
            Discover the ecology, history, and ongoing conservation projects in this remarkable 57-acre urban woodland.
          </p>
          <span class="mt-3 inline-block text-sm font-sans font-semibold text-forest-700 group-hover:underline">
            Explore the woods →
          </span>
        </div>
      </a>

      <!-- Water Testing -->
      <a href="/water-testing" class="group block bg-white rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow border border-gray-100">
        <div class="h-48 overflow-hidden relative">
          <img src="/images/PXL_20240330_075852233.MP.jpg" alt="Gledhow Valley pond in winter" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
          <span class="absolute bottom-1 right-2 text-[10px] text-white/70 font-sans">© Simon Conyers</span>
        </div>
        <div class="p-5">
          <h2 class="font-heading font-bold text-forest-800 text-2xl mb-2 group-hover:text-forest-600 transition-colors">Water Testing</h2>
          <p class="text-earth-700 text-sm font-body leading-relaxed">
            Our citizen science programme monitors water quality in Gledhow Beck — Leeds's urban stream running through the valley.
          </p>
          <span class="mt-3 inline-block text-sm font-sans font-semibold text-forest-700 group-hover:underline">
            See our results →
          </span>
        </div>
      </a>

      <!-- Green Fair -->
      <a href="/green-fair" class="group block bg-white rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow border border-gray-100">
        <div class="h-48 overflow-hidden relative">
          <img src="/images/Green Fair.jpeg" alt="Crowds enjoying the Gledhow Valley Green Fair" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
          <span class="absolute bottom-1 right-2 text-[10px] text-white/70 font-sans">© Hazel Gregory</span>
        </div>
        <div class="p-5">
          <h2 class="font-heading font-bold text-forest-800 text-2xl mb-2 group-hover:text-forest-600 transition-colors">Green Fair</h2>
          <p class="text-earth-700 text-sm font-body leading-relaxed">
            The annual Gledhow Valley Green Fair — Sunday 12 July 2026, 11am–4pm. Free entry. Gledhow Valley Road car-free for the day.
          </p>
          <span class="mt-3 inline-block text-sm font-sans font-semibold text-fair-700 group-hover:underline">
            Find out more →
          </span>
        </div>
      </a>
    </div>
  </section>

  <!-- LATEST NEWS -->
  <section class="bg-bluebell-50 border-y border-bluebell-100 py-14 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-baseline justify-between mb-10">
        <h2 class="font-heading font-bold text-forest-900 text-3xl md:text-4xl">Latest News</h2>
        <a href="/news" class="text-sm font-sans font-semibold text-forest-700 hover:underline">All news →</a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {latestNews.map(post => (
          <article class="border-l-4 border-bluebell-400 pl-5">
            <time class="text-xs font-sans text-earth-500 uppercase tracking-wide" datetime={post.data.date.toISOString()}>
              {formatDate(post.data.date)}
            </time>
            <h3 class="font-heading font-semibold text-forest-800 text-xl mt-1 mb-2 leading-snug">
              <a href={`/news/${post.slug}`} class="hover:text-bluebell-600 transition-colors">{post.data.title}</a>
            </h3>
            {post.data.excerpt && (
              <p class="text-earth-700 text-sm font-body leading-relaxed">{post.data.excerpt}</p>
            )}
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- UPCOMING EVENTS -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14 md:py-20">
    <div class="flex items-baseline justify-between mb-8">
      <h2 class="font-heading font-bold text-forest-900 text-3xl md:text-4xl">Upcoming Events</h2>
      <a href="/events" class="text-sm font-sans font-semibold text-forest-700 hover:underline">All events →</a>
    </div>
    {upcomingEvents.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {upcomingEvents.map(event => (
          <article class="bg-white rounded-lg p-5 border border-gray-100 shadow-sm">
            <div class="flex items-start gap-4">
              <div class="shrink-0 bg-forest-700 text-white rounded text-center w-14 py-2">
                <div class="text-xs font-sans font-medium uppercase">
                  {event.data.date.toLocaleDateString('en-GB', { month: 'short' })}
                </div>
                <div class="text-2xl font-heading font-bold leading-none">
                  {event.data.date.getDate()}
                </div>
              </div>
              <div>
                <h3 class="font-heading font-semibold text-forest-800 text-lg leading-snug mb-1">
                  <a href={`/events/${event.slug}`} class="hover:text-forest-600 transition-colors">{event.data.title}</a>
                </h3>
                {event.data.time && (
                  <p class="text-xs font-sans text-earth-500">{event.data.time}</p>
                )}
                <p class="text-xs font-sans text-earth-500">{event.data.location}</p>
              </div>
            </div>
          </article>
        ))}
      </div>
    ) : (
      <p class="text-earth-600 font-body">No upcoming events at the moment — check back soon.</p>
    )}
  </section>

  <!-- JOIN CTA BANNER -->
  <section class="bg-earth-700 text-white py-12 md:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading font-bold text-3xl md:text-4xl mb-4 text-cream-100">
        Help us protect the woods
      </h2>
      <p class="font-body text-cream-200 text-lg mb-8 max-w-2xl mx-auto leading-relaxed">
        Membership costs just £5 per year — or £50 for lifetime membership. Your support helps fund conservation work, citizen science, and community events in the valley.
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="/get-involved" class="bg-white text-earth-800 hover:bg-cream-200 font-sans font-bold px-8 py-3 rounded transition-colors">
          Get involved today
        </a>
        <a href="/contact" class="bg-earth-600 hover:bg-earth-500 border border-earth-400 text-white font-sans font-semibold px-6 py-3 rounded transition-colors">
          Get in touch
        </a>
      </div>
    </div>
  </section>
</Base>
