---
import Base from '../layouts/Base.astro';
import MailerLiteForm from '../components/MailerLiteForm.astro';
---

<Base
  title="Join Us"
  description="Join Friends of Gledhow Valley Woods — membership costs £5/year or £50 for life. Sign up for our mailing list to stay in touch."
  section="join-us"
>
  <section class="bg-earth-700 text-white py-16 md:py-24 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-earth-900 to-earth-700 opacity-90"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="font-heading font-bold text-5xl md:text-7xl text-white mb-5">Join Us</h1>
      <p class="font-body text-cream-200 text-xl max-w-2xl leading-relaxed">
        Become a member of FGVW and help protect Gledhow Valley Woods for future generations. Membership starts at just £5 per year.
      </p>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">

      <!-- MEMBERSHIP FORM -->
      <div>
        <h2 class="font-heading font-bold text-forest-900 text-3xl mb-2">Become a member</h2>
        <p class="text-earth-700 font-body leading-relaxed mb-6">
          FGVW membership supports our conservation work, citizen science, and community events. Membership fees are subject to change.
        </p>

        <!-- Membership options -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
          <div class="bg-white border-2 border-forest-600 rounded-lg p-5">
            <div class="font-heading font-bold text-forest-700 text-4xl">£5</div>
            <div class="font-sans font-semibold text-forest-800 mt-1">Annual membership</div>
            <div class="text-earth-600 font-body text-sm mt-1">Per person, per year</div>
          </div>
          <div class="bg-forest-800 text-white rounded-lg p-5">
            <div class="font-heading font-bold text-cream-100 text-4xl">£50</div>
            <div class="font-sans font-semibold text-cream-100 mt-1">Lifetime membership</div>
            <div class="text-forest-200 font-body text-sm mt-1">A one-off payment for life</div>
          </div>
        </div>
        <p class="text-xs font-sans text-earth-500 mb-8">Membership fees are subject to change. Please check this page for current rates before joining.</p>

        <!-- Join form -->
        <form class="space-y-5" action="#" method="post" novalidate>
          <div>
            <label for="join-name" class="block text-sm font-sans font-semibold text-earth-800 mb-1">Full name <span class="text-red-600">*</span></label>
            <input
              type="text" id="join-name" name="name" required
              class="w-full border border-cream-400 rounded px-4 py-2.5 font-body text-earth-800 focus:outline-none focus:border-forest-500 focus:ring-1 focus:ring-forest-500"
              placeholder="Your full name"
            />
          </div>
          <div>
            <label for="join-email" class="block text-sm font-sans font-semibold text-earth-800 mb-1">Email address <span class="text-red-600">*</span></label>
            <input
              type="email" id="join-email" name="email" required
              class="w-full border border-cream-400 rounded px-4 py-2.5 font-body text-earth-800 focus:outline-none focus:border-forest-500 focus:ring-1 focus:ring-forest-500"
              placeholder="you@example.com"
            />
          </div>
          <div>
            <label for="join-type" class="block text-sm font-sans font-semibold text-earth-800 mb-1">Membership type <span class="text-red-600">*</span></label>
            <select
              id="join-type" name="membership_type" required
              class="w-full border border-cream-400 rounded px-4 py-2.5 font-body text-earth-800 focus:outline-none focus:border-forest-500 focus:ring-1 focus:ring-forest-500 bg-white"
            >
              <option value="">Please select…</option>
              <option value="annual">Annual — £5 per year</option>
              <option value="lifetime">Lifetime — £50</option>
            </select>
          </div>
          <div>
            <label for="join-address" class="block text-sm font-sans font-semibold text-earth-800 mb-1">Address <span class="text-earth-400 font-normal">(optional)</span></label>
            <textarea
              id="join-address" name="address" rows="3"
              class="w-full border border-cream-400 rounded px-4 py-2.5 font-body text-earth-800 focus:outline-none focus:border-forest-500 focus:ring-1 focus:ring-forest-500 resize-y"
              placeholder="Your postal address"
            ></textarea>
          </div>

          <!-- GDPR consent -->
          <div class="flex items-start gap-3">
            <input type="checkbox" id="join-consent" name="consent" required class="mt-1 h-4 w-4 rounded border-cream-400 text-forest-700 focus:ring-forest-500" />
            <label for="join-consent" class="text-sm font-body text-earth-700 leading-relaxed">
              I agree to receive occasional emails from FGVW about news, events, and the Green Fair. We will never share your data with third parties. You can unsubscribe at any time.
              See our <a href="/privacy-policy" class="text-forest-700 underline">Privacy Policy</a>. <span class="text-red-600">*</span>
            </label>
          </div>

          <!-- PAYMENT PROVIDER PLACEHOLDER -->
          <div class="border-2 border-dashed border-earth-400 rounded-lg p-5 bg-earth-50">
            <p class="font-sans font-bold text-earth-700 text-sm uppercase tracking-wide mb-2">⚠ PAYMENT PROVIDER TBC</p>
            <p class="font-body text-earth-600 text-sm leading-relaxed">
              Online payment will be handled here. The payment provider integration (Stripe / PayPal / GoCardless) is to be confirmed and will be added to this form. Until payment is integrated, please <a href="/contact" class="text-forest-700 underline">contact us</a> to arrange membership by bank transfer or cheque.
            </p>
          </div>
          <!-- END PAYMENT PLACEHOLDER -->

          <button
            type="submit"
            class="w-full bg-forest-700 hover:bg-forest-800 text-white font-sans font-bold py-3 px-6 rounded transition-colors cursor-not-allowed opacity-70"
            disabled
            title="Online payment not yet available — please contact us"
          >
            Join FGVW (payment integration coming soon)
          </button>
        </form>
      </div>

      <!-- MAILING LIST -->
      <div>
        <h2 class="font-heading font-bold text-forest-900 text-3xl mb-2">Stay in touch</h2>
        <p class="text-earth-700 font-body leading-relaxed mb-6">
          Sign up to our mailing list to receive occasional updates about FGVW news, conservation work, events, and the Green Fair. You don't need to be a member to subscribe.
        </p>
        <div class="bg-white border border-cream-400 rounded-lg p-6 shadow-sm">
          <MailerLiteForm />
        </div>
      </div>

    </div>
  </section>
</Base>
