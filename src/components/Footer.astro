---
import MailerLiteForm from './MailerLiteForm.astro';
const year = new Date().getFullYear();
---

<footer class="bg-forest-900 text-cream-200 mt-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-8">

      <!-- About column -->
      <div class="md:col-span-2">
        <img
          src="/images/fgvw-logo.png"
          alt="Friends of Gledhow Valley Woods"
          class="h-12 w-auto mb-4 opacity-90"
        />
        <p class="text-sm text-cream-300 leading-relaxed mb-3">
          Friends of Gledhow Valley Woods is a registered charity protecting and enhancing Gledhow Valley Woods in north Leeds since 1996.
        </p>
        <p class="text-xs text-cream-400">
          Registered Charity No. <strong class="text-cream-200">1169599</strong>
        </p>
        <!-- MailerLite signup -->
        <div class="mt-4">
          <MailerLiteForm />
        </div>
      </div>

      <!-- Pages column -->
      <div>
        <h3 class="font-heading font-semibold text-cream-100 mb-3 text-lg">The Site</h3>
        <ul class="space-y-1.5 text-sm font-sans">
          <li><a href="/the-woods" class="text-cream-300 hover:text-cream-100 transition-colors">The Woods</a></li>
          <li><a href="/water-testing" class="text-cream-300 hover:text-cream-100 transition-colors">Water Testing</a></li>
          <li><a href="/green-fair" class="text-cream-300 hover:text-cream-100 transition-colors">Green Fair</a></li>
          <li><a href="/about-us" class="text-cream-300 hover:text-cream-100 transition-colors">About Us</a></li>
          <li><a href="/news" class="text-cream-300 hover:text-cream-100 transition-colors">News</a></li>
          <li><a href="/events" class="text-cream-300 hover:text-cream-100 transition-colors">Events</a></li>
          <li><a href="/get-involved" class="text-cream-300 hover:text-cream-100 transition-colors">Get Involved</a></li>
          <li><a href="/contact" class="text-cream-300 hover:text-cream-100 transition-colors">Contact</a></li>
        </ul>
      </div>

      <!-- Legal & social column -->
      <div>
        <h3 class="font-heading font-semibold text-cream-100 mb-3 text-lg">Connect</h3>
        <div class="flex gap-3 mb-4">
          <a
            href="https://www.facebook.com/share/18yRD9YstL/?mibextid=wwXIfr"
            class="text-cream-300 hover:text-cream-100 transition-colors"
            aria-label="Facebook"
            target="_blank" rel="noopener noreferrer"
          >
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a
            href="https://twitter.com/gledhowwoods"
            class="text-cream-300 hover:text-cream-100 transition-colors"
            aria-label="Twitter / X"
            target="_blank" rel="noopener noreferrer"
          >
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
        </div>
        <ul class="space-y-1.5 text-sm font-sans">
          <li>
            <a
              href="https://register-of-charities.charitycommission.gov.uk/charity-search"
              target="_blank" rel="noopener noreferrer"
              class="text-cream-300 hover:text-cream-100 transition-colors"
            >Charity Commission</a>
          </li>
          <li>
            <a href="mailto:contact@fgvw.co.uk" class="text-cream-300 hover:text-cream-100 transition-colors">contact@fgvw.co.uk</a>
          </li>
          <li><a href="/privacy-policy" class="text-cream-300 hover:text-cream-100 transition-colors">Privacy Policy</a></li>
          <li><a href="/cookie-policy" class="text-cream-300 hover:text-cream-100 transition-colors">Cookie Policy</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-forest-700 pt-6 text-xs text-cream-400 font-sans flex flex-col sm:flex-row justify-between gap-2">
      <p>© {year} Friends of Gledhow Valley Woods. Registered Charity No. 1169599.</p>
      <p>Gledhow Valley Woods, north Leeds, West Yorkshire</p>
    </div>
  </div>
</footer>
