<div
  id="cookie-banner"
  class="fixed bottom-0 left-0 right-0 z-50 bg-forest-900 text-cream-100 p-4 shadow-lg"
  style="display:none"
  role="region"
  aria-label="Cookie notice"
>
  <div class="max-w-7xl mx-auto flex flex-col sm:flex-row items-center gap-4">
    <p class="text-sm font-sans text-cream-200 flex-1">
      This website uses only essential cookies needed to make the site work.
      See our <a href="/cookie-policy" class="underline hover:text-cream-100">Cookie Policy</a> for details.
    </p>
    <button
      id="cookie-accept"
      class="shrink-0 bg-forest-500 hover:bg-forest-400 text-white px-5 py-2 rounded text-sm font-sans font-medium transition-colors"
    >
      Got it
    </button>
  </div>
</div>

<script>
  const banner = document.getElementById('cookie-banner');
  const btn    = document.getElementById('cookie-accept');

  if (!sessionStorage.getItem('cookie-accepted')) {
    banner!.style.display = 'block';
  }

  btn?.addEventListener('click', () => {
    sessionStorage.setItem('cookie-accepted', '1');
    banner!.style.display = 'none';
  });
</script>
