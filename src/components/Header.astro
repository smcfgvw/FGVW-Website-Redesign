---
interface Props {
  section?: string;
}
const { section = '' } = Astro.props;

const nav = [
  { label: 'The Woods',     href: '/the-woods',     prominent: true },
  { label: 'Water Testing', href: '/water-testing',  prominent: true },
  { label: 'Green Fair',    href: '/green-fair',     prominent: true, fair: true },
  { label: 'About Us',      href: '/about-us',       prominent: false },
  { label: 'News',          href: '/news',           prominent: false },
  { label: 'Events',        href: '/events',         prominent: false },
  { label: 'Contact',       href: '/contact',        prominent: false },
];

const getInvolved = [
  { label: 'Volunteering',      href: '/get-involved/volunteering' },
  { label: 'Becoming a Member', href: '/get-involved/membership' },
  { label: 'Donating',          href: '/get-involved/donating' },
];
---

<header class="bg-white shadow-sm border-b-4 border-forest-700 sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 md:h-20">

      <!-- Logo / Site name -->
      <a href="/" class="flex items-center gap-3 shrink-0">
        <img
          src="/images/fgvw-logo.png"
          alt="Friends of Gledhow Valley Woods"
          class="h-10 md:h-14 w-auto"
          loading="eager"
        />
        <span class="hidden lg:block font-heading font-semibold text-forest-800 text-lg leading-tight">
          Friends of Gledhow<br />Valley Woods
        </span>
      </a>

      <!-- Desktop navigation -->
      <nav class="hidden md:flex items-center gap-1 lg:gap-2" aria-label="Main navigation">
        {nav.map(item => (
          <a
            href={item.href}
            class:list={[
              'px-3 py-1.5 rounded text-sm font-sans font-medium transition-colors whitespace-nowrap',
              item.fair
                ? 'bg-fair-600 text-white hover:bg-fair-700 font-semibold'
                : item.prominent
                  ? 'bg-forest-700 text-white hover:bg-forest-800 font-semibold'
                  : 'text-forest-800 hover:bg-forest-50 hover:text-forest-900',
            ]}
          >
            {item.label}
          </a>
        ))}

        <!-- Get Involved — prominent CTA with dropdown -->
        <div id="get-involved-wrap" class="relative ml-1 lg:ml-3">
          <button
            id="get-involved-toggle"
            aria-haspopup="true"
            aria-expanded="false"
            class="flex items-center gap-1.5 bg-bluebell-700 hover:bg-bluebell-800 text-white font-sans font-bold text-sm px-5 py-2 rounded-full shadow-sm transition-colors whitespace-nowrap"
          >
            Get Involved
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div
            id="get-involved-menu"
            class="hidden absolute right-0 mt-2 w-56 bg-white rounded-lg shadow-lg border border-cream-300 py-2 z-50"
          >
            <a href="/get-involved" class="block px-4 py-2 text-sm font-sans font-semibold text-bluebell-900 hover:bg-bluebell-50">
              Overview
            </a>
            <div class="my-1 border-t border-cream-200"></div>
            {getInvolved.map(item => (
              <a href={item.href} class="block px-4 py-2 text-sm font-sans text-bluebell-700 hover:bg-bluebell-50 hover:text-bluebell-900">
                {item.label}
              </a>
            ))}
          </div>
        </div>
      </nav>

      <!-- Mobile hamburger -->
      <button
        id="menu-toggle"
        class="md:hidden p-2 rounded text-forest-800 hover:bg-forest-50"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-forest-200">
    <nav class="max-w-7xl mx-auto px-4 py-3 flex flex-col gap-1" aria-label="Mobile navigation">
      {nav.map(item => (
        <a
          href={item.href}
          class:list={[
            'px-4 py-2.5 rounded text-sm font-sans font-medium transition-colors',
            item.fair
              ? 'bg-fair-600 text-white hover:bg-fair-700 font-semibold'
              : item.prominent
                ? 'bg-forest-700 text-white hover:bg-forest-800 font-semibold'
                : 'text-forest-800 hover:bg-forest-50',
          ]}
        >
          {item.label}
        </a>
      ))}

      <!-- Get Involved — prominent CTA, far end of mobile menu too -->
      <div class="mt-2 pt-2 border-t border-cream-200">
        <p class="px-4 pb-1 text-xs font-sans font-bold uppercase tracking-wide text-bluebell-700">Get Involved</p>
        <a href="/get-involved" class="block px-4 py-2.5 rounded text-sm font-sans font-bold bg-bluebell-700 text-white hover:bg-bluebell-800 transition-colors">
          Overview
        </a>
        {getInvolved.map(item => (
          <a href={item.href} class="block px-4 py-2.5 rounded text-sm font-sans font-medium text-bluebell-800 hover:bg-bluebell-50">
            {item.label}
          </a>
        ))}
      </div>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu   = document.getElementById('mobile-menu');
  const iconOpen  = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
    iconOpen?.classList.toggle('hidden', open);
    iconClose?.classList.toggle('hidden', !open);
  });

  const giToggle = document.getElementById('get-involved-toggle');
  const giMenu   = document.getElementById('get-involved-menu');
  const giWrap   = document.getElementById('get-involved-wrap');

  giToggle?.addEventListener('click', (e) => {
    e.stopPropagation();
    const isHidden = giMenu?.classList.toggle('hidden') === false;
    giToggle.setAttribute('aria-expanded', String(isHidden));
  });

  document.addEventListener('click', (e) => {
    if (giWrap && !giWrap.contains(e.target)) {
      giMenu?.classList.add('hidden');
      giToggle?.setAttribute('aria-expanded', 'false');
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      giMenu?.classList.add('hidden');
      giToggle?.setAttribute('aria-expanded', 'false');
    }
  });
</script>
